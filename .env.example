# ---------------------------------------------------------------------------
# CPPD Application System — environment variables
#
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
# Every variable here is validated at startup by src/lib/env.ts (fail-fast).
# ---------------------------------------------------------------------------

# Base URL of the self-hosted Supabase instance (Kong/gateway URL).
# Exposed to the browser. Example: https://supabase.cppd.example
NEXT_PUBLIC_SUPABASE_URL=

# Supabase ANON (publishable) key. Safe to expose to the browser — Row Level
# Security enforces all access rules in Postgres.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public origin of this app — the Cloudflare Tunnel URL. Used for auth
# redirects and absolute links. Example: https://apply.cppd.example
NEXT_PUBLIC_SITE_URL=

# Supabase SERVICE ROLE key — FULL database access, bypasses RLS.
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_ and never import into client
# components. Used only by trusted server code (e.g. signed-URL issuance).
SUPABASE_SERVICE_ROLE_KEY=
